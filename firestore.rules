rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function tokenRole() {
      return request.auth.token.role != null ? request.auth.token.role : "";
    }

    function roleFromUserDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "";
    }

    function isAdmin() {
      return isSignedIn() && (
        tokenRole() in ["admin", "super_admin"] ||
        roleFromUserDoc() in ["admin", "super_admin"]
      );
    }

    match /products/{docId} {
      allow read: if resource != null && resource.data.status == "published";
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /blogs/{docId} {
      allow read: if resource != null && resource.data.status == "published";
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
